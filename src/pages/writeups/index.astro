---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';

const writeups = (await getCollection('writeups', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Writeups — Xavier Ogay"
  description="Notes and writeups on binary analysis, systems security, and low-level engineering."
>
  <section class="section">
    <div class="container">
      <SectionHeading index="~" label="cat writeups/*" title="Writeups" />
      <ul class="list">
        {
          writeups.map((w) => (
            <li data-reveal>
              <a class="entry" href={`/writeups/${w.id}`}>
                <p class="date mono">
                  {w.data.pubDate.toLocaleDateString('en-GB', {
                    day: '2-digit',
                    month: 'short',
                    year: 'numeric',
                  })}
                </p>
                <div>
                  <h2>{w.data.title}</h2>
                  <p class="desc">{w.data.description}</p>
                  {w.data.tags.length > 0 && (
                    <ul class="tags">
                      {w.data.tags.map((t) => (
                        <li class="tag">{t}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .list {
    list-style: none;
    padding: 0;
    max-width: 50rem;
  }

  .entry {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-2);
    border-bottom: 1px solid var(--border);
    transition: background var(--transition-fast);
  }

  .entry:hover {
    background: var(--bg-1);
  }

  .entry:hover h2 {
    color: var(--red);
  }

  .date {
    color: var(--text-faint);
    font-size: var(--text-xs);
    padding-top: 0.4rem;
  }

  h2 {
    font-size: var(--text-lg);
    transition: color var(--transition-fast);
  }

  .desc {
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-1);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin-top: var(--space-2);
  }

  @media (max-width: 600px) {
    .entry {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
