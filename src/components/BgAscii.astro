---
/* Faint ASCII watermark concentrated on the left/right borders (content sits
   in the middle), built from several layers that each scroll at a different
   speed for a real multi-depth parallax. Decorative only. */

const HEX = '0123456789abcdef';
const PRINT = 'etaoinshrdlucmfwypvbgkqjxz./_-()[]{}<>=;:*&^%$#@!01';

// Deterministic PRNG so markup is stable across builds.
let seed = 0x1337c0de;
const rand = () => {
  seed = (seed * 1103515245 + 12345) & 0x7fffffff;
  return seed / 0x7fffffff;
};
const pick = (s: string) => s[Math.floor(rand() * s.length)];
const byte = () => `${pick(HEX)}${pick(HEX)}`;

// Left layer: narrow hexdump column.
const left = Array.from({ length: 80 }, (_, i) => {
  const off = (i * 8).toString(16).padStart(6, '0');
  const bytes = Array.from({ length: 6 }, byte).join(' ');
  const ascii = Array.from({ length: 6 }, () => (rand() > 0.4 ? pick(PRINT) : '.')).join('');
  return `${off}  ${bytes} |${ascii}|`;
}).join('\n');

// Right layer: binary stream.
const right = Array.from({ length: 80 }, () =>
  Array.from({ length: 3 }, () =>
    Array.from({ length: 8 }, () => (rand() > 0.5 ? '1' : '0')).join('')
  ).join(' ')
).join('\n');

// Far layer: very sparse, wide hex grid that barely moves.
const far = Array.from({ length: 60 }, () =>
  Array.from({ length: 22 }, byte).join('  ')
).join('\n');

// Near layer: floating opcodes / tokens, moves fastest.
const TOKENS = [
  '0xDEADBEEF', '7f45 4c46', 'ELF64', 'mov rax, rdi', 'xor eax, eax', 'jmp $+2',
  'ret', '0x00400000', 'nop', '\\x90\\x90', 'int3', 'syscall', 'call rsp',
  'SIGSEGV', 'PT_LOAD', '.text', '0xCAFEBABE', 'leave', 'push rbp', 'shellcode',
];
const near = Array.from({ length: 22 }, (_, i) => {
  const indent = ' '.repeat(Math.floor(rand() * 6));
  return `${indent}${TOKENS[Math.floor(rand() * TOKENS.length)]}`;
}).join('\n\n');
---

<div class="bg-ascii" aria-hidden="true">
  <pre class="layer far" data-speed="0.05">{far}</pre>
  <pre class="layer left" data-speed="0.22">{left}</pre>
  <pre class="layer right" data-speed="0.36">{right}</pre>
  <pre class="layer near" data-speed="0.6">{near}</pre>
</div>

<style>
  .bg-ascii {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
    user-select: none;
  }

  .layer {
    position: absolute;
    top: -10vh;
    margin: 0;
    font-family: var(--font-mono);
    color: var(--red);
    white-space: pre;
    will-change: transform;
  }

  .far {
    left: 50%;
    transform: translateX(-50%);
    width: max-content;
    font-size: 0.85rem;
    line-height: 2.1;
    letter-spacing: 0.18em;
    opacity: 0.022;
  }

  .left {
    left: clamp(0.5rem, 3vw, 4.5rem);
    font-size: 0.72rem;
    line-height: 1.55;
    opacity: 0.07;
  }

  .right {
    right: clamp(0.5rem, 3vw, 4.5rem);
    text-align: right;
    font-size: 0.72rem;
    line-height: 1.55;
    opacity: 0.07;
  }

  .near {
    right: clamp(7rem, 20vw, 17rem);
    font-size: 0.78rem;
    line-height: 1.4;
    letter-spacing: 0.05em;
    opacity: 0.05;
  }

  /* On narrow screens the gutters vanish — fade the edge columns so they
     never fight the centered content. */
  @media (max-width: 900px) {
    .left,
    .right,
    .near {
      opacity: 0.035;
    }
    .near {
      display: none;
    }
  }
</style>

<script>
  const layers = Array.from(
    document.querySelectorAll<HTMLElement>('.bg-ascii [data-speed]')
  ).map((el) => ({ el, speed: parseFloat(el.dataset.speed || '0') }));

  const baseX = (el: HTMLElement) => (el.classList.contains('far') ? 'translateX(-50%) ' : '');

  let ticking = false;
  const apply = () => {
    const y = window.scrollY;
    for (const { el, speed } of layers) {
      el.style.transform = `${baseX(el)}translate3d(0, ${(y * speed).toFixed(1)}px, 0)`;
    }
    ticking = false;
  };

  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(apply);
      }
    },
    { passive: true }
  );
  apply();
</script>
