---

<section id="experience" class="section">
  <div class="container">
    <SectionHeading index="01" label="background" title="Experience & Education" />
    <div class="columns">
      <div data-reveal>
        <h3 class="col-title mono">experience</h3>
        <ol class="timeline">
          {
            experience.map((e) => (
              <li>
                <p class="period mono">{e.period}</p>
                <p class="entry-title">{e.title}</p>
                <div class="place-row">
                  <p class="place">{e.place}</p>
                  {e.logos && (
                    <span class="logos">
                      {e.logos.map((logo) => (
                        <Image src={logo} alt="" height={26} class="logo" />
                      ))}
                    </span>
                  )}
                </div>
                {e.details?.map((d) => <p class="detail">{d}</p>)}
              </li>
            ))
          }
        </ol>
      </div>
      <div data-reveal style="--reveal-delay: 0.1s">
        <h3 class="col-title mono">education</h3>
        <ol class="timeline">
          {
            education.map((e) => (
              <li>
                <p class="period mono">{e.period}</p>
                <p class="entry-title">{e.title}</p>
                <div class="place-row">
                  <p class="place">{e.place}</p>
                  {e.logos && (
                    <span class="logos">
                      {e.logos.map((logo) => (
                        <Image src={logo} alt="" height={26} class="logo" />
                      ))}
                    </span>
                  )}
                </div>
                {e.details?.map((d) => <p class="detail">{d}</p>)}
              </li>
            ))
          }
        </ol>
        <details class="coursework">
          <summary class="mono">selected coursework</summary>
          <div class="course-grid">
            {
              coursework.map((group) => (
                <div class="course-group">
                  <p class="course-cat mono">{group.category}</p>
                  <ul>
                    {group.courses.map((c) => (
                      <li>
                        <a class="link" href={c.url} target="_blank" rel="noopener noreferrer">
                          {c.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
        </details>
      </div>
    </div>
    <div class="skills" data-reveal>
      <h3 class="col-title mono">core skills</h3>
      <ul>
        {skills.map((s) => <li class="tag">{s}</li>)}
      </ul>
    </div>
  </div>
</section>

<style>
  .columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: var(--space-7);
  }

  .col-title {
    color: var(--text-faint);
    font-weight: 500;
    margin-bottom: var(--space-4);
    text-transform: lowercase;
    letter-spacing: 0.05em;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--border);
  }

  .timeline li {
    position: relative;
    padding: 0 0 var(--space-5) var(--space-4);
  }

  .timeline li::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 0.45rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--red);
  }

  .period {
    color: var(--red-soft);
    font-size: var(--text-xs);
    margin-bottom: var(--space-1);
  }

  .entry-title {
    font-weight: 600;
  }

  .place-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .place {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .logos {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .logos :global(.logo) {
    height: 22px;
    width: auto;
    border-radius: 3px;
    filter: grayscale(1) opacity(0.7);
    transition: filter 0.3s ease;
  }

  .timeline li:hover .logos :global(.logo) {
    filter: grayscale(0) opacity(1);
  }

  .detail {
    color: var(--text-faint);
    font-size: var(--text-sm);
    margin-top: var(--space-1);
  }

  .coursework {
    margin-top: var(--space-3);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: var(--space-3);
  }

  .coursework summary {
    cursor: pointer;
    color: var(--text-muted);
  }

  .coursework summary:hover {
    color: var(--red);
  }

  .course-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .course-cat {
    color: var(--red-soft);
    font-size: var(--text-xs);
    margin-bottom: var(--space-2);
  }

  .course-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .course-group li {
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  .skills {
    margin-top: var(--space-7);
  }

  .skills ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
  }
</style>
