---
interface Props {
  title: string;
  variant?: 'red' | 'amber' | 'blue' | 'teal';
}

const { title, variant = 'red' } = Astro.props;
---

<aside class:list={['callout', variant]}>
  <p class="callout-title">{title}</p>
  <slot />
</aside>

<style>
  .callout {
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent, var(--red));
    border-radius: 0 8px 8px 0;
    background: var(--bg-1);
    padding: var(--space-3) var(--space-4);
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
  }

  .callout.red {
    --accent: #ec1c24;
  }

  .callout.amber {
    --accent: #e2a93c;
  }

  .callout.blue {
    --accent: #4d9de0;
  }

  .callout.teal {
    --accent: #3cbfae;
  }

  .callout-title {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--accent, var(--red));
    margin-bottom: var(--space-2);
  }

  .callout :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
